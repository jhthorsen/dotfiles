command = /opt/homebrew/bin/bash
theme = Kanagawa Wave
background-opacity = 1
#background-blur-radius = 0
adjust-cell-width = 0%
adjust-cell-height = 5%
font-family = ""
font-family = "Hack Nerd Font"
font-family = "JetBrains Mono"
font-feature = -calt
font-feature = -dlig
font-feature = -liga
split-divider-color = #263646
shell-integration-features = sudo, ssh-env, ssh-terminfo
font-size = 13.5
unfocused-split-opacity = 0.9
scrollbar = never
cursor-opacity = 0.7
mouse-hide-while-typing = true
#focus-follows-mouse = true
quit-after-last-window-closed = true
macos-titlebar-style = tabs

keybind = global:super+alt+p=toggle_quick_terminal

keybind = super+j=goto_split:bottom
keybind = super+k=goto_split:top
keybind = super+h=goto_split:left
keybind = super+l=goto_split:right

keybind = super+shift+j=resize_split:down,20
keybind = super+shift+k=resize_split:up,20
keybind = super+shift+h=resize_split:left,20
keybind = super+shift+l=resize_split:right,20

keybind = super+z=toggle_split_zoom

shell-integration-features = ssh-env,ssh-terminfo
