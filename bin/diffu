#!/usr/bin/env perl
use v5.10;
use strict;
use warnings;

$ENV{PAGER} = "less -FRX -x2" if !$ENV{PAGER} || $ENV{PAGER} =~ /^diffu/;
exec $ENV{PAGER} if !-t STDOUT || -t STDIN;

my ($height, $bat_pager, @buffer) = $ENV{ROWS} || 80;
$ENV{PAGER} = "";
while (defined(local $_ = readline STDIN)) {
  $bat_pager //= qq(less -FRX -x2 -p '^(commit|diff)') if /^\S*(diff --)/;
  push @buffer, $_;
  last if @buffer == $height;
}

my $PAGER;
if ($bat_pager && @buffer == $height) {
  open($PAGER, "|-", qw(bat -pl diff --pager), $bat_pager) || die $!;
} else {
  open($PAGER, "|-", qw(less -FRX -x2)) || die $!;
}

print {$PAGER} shift @buffer while @buffer;
print {$PAGER} $_ while readline STDIN;
